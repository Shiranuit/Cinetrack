# Cinetrack edge (one Caddy, two vhosts), sitting BEHIND Cloudflare's proxy:
#   WEB_DOMAIN (e.g. app.cine-track.com) -> the Flutter web SPA
#   API_DOMAIN (e.g. api.cine-track.com) -> the Rust backend
# Both names are proxied (orange-cloud) in Cloudflare, so:
#   * TLS is served with a Cloudflare Origin Certificate (mounted at /etc/caddy/origin/),
#     NOT Let's Encrypt — Cloudflare intercepts the ACME challenges on :443. Set
#     Cloudflare's SSL/TLS mode to "Full (strict)".
#   * The origin only ever sees Cloudflare's edge IPs; the real visitor IP arrives in
#     the CF-Connecting-IP header.
#
# "Cloudflare-only" is enforced at the NETWORK layer by the host firewall
# (deploy/cloudflare-firewall.service + scripts/firewall-cloudflare.sh): it drops any
# packet to 80/443 not from Cloudflare's edge, and AUTO-REFRESHES Cloudflare's ranges
# weekly. So we deliberately DON'T duplicate a static IP allowlist here — a stale one
# would 403 legit users whenever Cloudflare adds a range. And because the firewall
# guarantees every request comes from Cloudflare, we can trust CF-Connecting-IP below.
#
# The `mail` subdomain is NOT here (it's grey-cloud, served by Postfix on the host).
{
	admin off
	# No ACME: we serve an explicit origin cert (see the `tls` lines). If you ever
	# grey-cloud these names, drop the `tls` lines and add `email {$ACME_EMAIL}`.
}

# ---- Web app --------------------------------------------------------------
{$WEB_DOMAIN} {
	tls /etc/caddy/origin/tls.crt /etc/caddy/origin/tls.key
	encode zstd gzip
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# CSP tuned for Flutter web: it loads the CanvasKit renderer (canvaskit.js +
		# .wasm) and the Roboto font from Google's CDN (www.gstatic.com /
		# fonts.gstatic.com), calls our API, and hotlinks TheTVDB posters over https.
		# script-src/connect-src allow gstatic for CanvasKit; connect-src/font-src allow
		# the font. Adjustable here without rebuilding the app bundle.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://{$API_DOMAIN} https://www.gstatic.com https://fonts.gstatic.com; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
		-Server
	}
	# --- Versioned, immutable caching -------------------------------------------
	# The web app is built with `--base-href=/{$APP_VERSION}/`, so every sub-resource
	# (main.dart.js, assets, canvaskit, fonts, ...) is requested under that per-release
	# prefix. That prefix IS the cache key: it's identical for a whole release and
	# changes only on the next deploy — so everything under it can be cached forever
	# with zero revalidation, no per-file content hashing needed. {$APP_VERSION} is
	# baked into this image (see Dockerfile), so it always matches the build's base-href.
	handle_path /{$APP_VERSION}/* {
		root * /srv
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}
	# The HTML shell (root `/` + SPA deep-link fallbacks like /reset-password) is served
	# from the same files but must ALWAYS revalidate, so a new deploy's base-href (and
	# thus the new version prefix) is picked up immediately. It's tiny.
	handle {
		root * /srv
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}

# ---- Backend API ----------------------------------------------------------
{$API_DOMAIN} {
	tls /etc/caddy/origin/tls.crt /etc/caddy/origin/tls.key
	encode zstd gzip
	reverse_proxy backend:8080 {
		# The origin only sees Cloudflare's IP as the peer, so {remote_host} is
		# useless for rate-limiting/audit. Cloudflare puts the true visitor IP in
		# CF-Connecting-IP; overwrite X-Forwarded-For with it so the backend's
		# last-hop client_ip is the real client. Safe to trust: the host firewall
		# drops any request that isn't from Cloudflare's edge.
		header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
	}
}
