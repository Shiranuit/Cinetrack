# Copy to scripts/backup.env and `chmod 600 scripts/backup.env`. Gitignored.
# Only the FTP_* values are required; everything else has sane defaults in backup.sh.
# (S3_ACCESS_KEY / S3_SECRET_KEY for Garage are read from .env.production.)

# --- Dedibackup FTPS (from the Dedibox console > Backup tab) ---
FTP_HOST=dedibackup-dc3.online.net
FTP_USER=sd-103686
FTP_PASS=CHANGE_ME            # the FTP backup password you set in the console
FTP_DIR=cinetrack             # remote folder for the backups
FTP_PORT=21                  # 21 for plain/explicit, 990 for implicit TLS
# Dedibox/Dedibackup is PLAIN FTP only (no FTPS), so use off. Other providers:
# explicit (AUTH TLS on 21) or implicit (TLS on 990).
FTP_TLS=off

# --- retention: space-driven, not a fixed count ---
QUOTA_BYTES=95000000000       # fill up to ~95 GB (leave headroom under the 100 GB cap)
MIN_KEEP=3                    # never prune below this many GOOD backups, even if full
MAX_KEEP=0                   # optional hard cap on count (0 = unlimited; space is the cap)
SUSPECT_KEEP=2               # keep at most this many parked suspect backups

# --- anomaly guard (protects good backups from a corrupt/empty DB) ---
SHRINK_RATIO=0.5             # reject if dump size or a row count < 0.5x the last good one
ABS_MIN_PG_BYTES=1000000000  # 1 GB: a healthy pg_dump is at least this big
MIN_TOC_ENTRIES=25           # pg_restore -l must list at least this many objects
MIN_USERS=1                  # there is always at least the owner account
MIN_SERIES=50000             # the mirrored catalog always has tens of thousands of series

# --- optional at-rest encryption (recommended once your key is set up) ---
# Public-key: the server only holds the recipient (public) key; keep the private key
# OFFLINE for restore. Example with age installed on the host:
# ENCRYPT_CMD='age -r age1yourpublickey...'
# The command reads the plaintext archive on stdin and must write ciphertext to stdout;
# any tool that does that works (age, gpg, openssl, or a `docker run -i ...` wrapper).
ENCRYPT_CMD=

# --- optional alerting on failure (message arrives on stdin) ---
# ALERT_CMD='curl -sS -X POST -H "Content-Type: application/json" -d @- https://hooks.slack.com/...'
ALERT_CMD=
