# Production env for production.docker-compose.yaml.
#   cp .env.production.example .env.production   # then fill in — NEVER commit .env.production
#   docker compose -f production.docker-compose.yaml --env-file .env.production up -d --build
# Generate every secret with:  openssl rand -hex 32

# ---------- Domains / TLS (one Caddy, two vhosts, auto-HTTPS) ----------
# Web app + API on separate subdomains. Both DNS records must point at this box,
# and ports 80/443 must be open. Configurable per deploy (Caddy reads them at runtime).
WEB_DOMAIN=app.cine-track.com
API_DOMAIN=api.cine-track.com
ACME_EMAIL=you@example.com

# API origin BAKED into the web bundle (for a local `up --build`) — must equal
# https://<API_DOMAIN>. In CI this comes from the `API_BASE` repository VARIABLE
# (it is NOT a secret; the URL is embedded in every client build and public anyway).
# The mobile/desktop apps use the SAME value:
#   flutter build apk --release --dart-define=API_BASE=https://api.cine-track.com
API_BASE=https://api.cine-track.com
# Optional, for a local web `up --build` (CI injects these from the git tag/repo):
APP_VERSION=dev
GITHUB_REPO=Shiranuit/Cinetrack

# ---------- Backend image (built by CI, pulled from GHCR) ----------
# Owner of the ghcr.io/<owner>/cinetrack-backend package (your GitHub username,
# lowercase). IMAGE_TAG is set by the deploy job to the release tag; `latest`
# also works for a manual `docker compose pull`.
GHCR_OWNER=shiranuit
IMAGE_TAG=latest

# ---------- Postgres ----------
POSTGRES_USER=cinetrack
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=cinetrack
# Host is the compose service name `postgres`:
DATABASE_URL=postgres://cinetrack:CHANGE_ME@postgres:5432/cinetrack
DB_MAX_CONNECTIONS=50

# ---------- Garage (S3, for avatars/backgrounds) ----------
GARAGE_RPC_SECRET=CHANGE_ME_hex32
GARAGE_ADMIN_TOKEN=CHANGE_ME_hex32
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_BUCKET=artwork
# Created on first boot by scripts/garage-init.sh, then paste them here:
S3_ACCESS_KEY=set-after-garage-init
S3_SECRET_KEY=set-after-garage-init

# ---------- TheTVDB ----------
THETVDB_API_KEY=your-project-api-key
THETVDB_BASE_URL=https://api4.thetvdb.com/v4
# Measured: the API tolerates far more; 200 is polite + fast. Lower for a lighter footprint.
THETVDB_MAX_RPS=200

# ---------- Backend ----------
PUBLIC_BASE_URL=https://api.cine-track.com
# Web app origin — used to build links in emails (password reset, invites).
WEB_BASE_URL=https://app.cine-track.com
JWT_SECRET=CHANGE_ME_hex32   # MUST be >= 32 chars (openssl rand -hex 32)

# ---------- Registration / invitations ----------
# false (default) = invite-only: new users need an invite code from an existing user.
# Flip to true to open public sign-ups.
ALLOW_PUBLIC_REGISTRATION=false

# ---------- Email (SMTP) — password reset + invitations ----------
# Default: the built-in self-hosted Postfix relay (the `mailer` service) over the
# private network — plain SMTP, no auth. Requires the mail DNS + reverse DNS from
# docs/mail-setup.md. Leave SMTP_USER/PASS empty. (To use an external provider
# instead, set SMTP_HOST/PORT to it, SMTP_TLS=starttls, and fill SMTP_USER/PASS.)
SMTP_HOST=mailer
SMTP_PORT=587
SMTP_TLS=none
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Cinetrack <no-reply@cine-track.com>
# Identity for the Postfix relay (must match your domain + the mail A/PTR records).
MAIL_DOMAIN=cine-track.com
MAIL_HOSTNAME=mail.cine-track.com
# Optional password pepper: set ONCE and NEVER change (existing hashes break). Blank = salt-only.
PASSWORD_PEPPER=
RUST_LOG=info

# Catalog behaviour (full explanation in .env.example):
#   CATALOG_MODE:  hybrid (resilient) | mirror (local-only, prod goal) | proxy
#   MIRROR_SCOPE:  full (whole catalog) | on-demand
CATALOG_MODE=hybrid
MIRROR_SCOPE=full
SYNC_INTERVAL_SECS=3600
ENRICH_INTERVAL_SECS=30
ENRICH_CONCURRENCY=64
BACKFILL_CONCURRENCY=20