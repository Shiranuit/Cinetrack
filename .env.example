# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# ---------- Postgres ----------
POSTGRES_USER=tvshow
POSTGRES_PASSWORD=change-me-dev-only
POSTGRES_DB=tvshow
# Consumed by the backend (host is the compose service name):
DATABASE_URL=postgres://tvshow:change-me-dev-only@postgres:5432/tvshow

# ---------- Integration-test Postgres (isolated) ----------
# `docker compose up -d postgres-test` starts a throwaway DB on host port 5433
# (compose `test` profile, tmpfs storage). The backend integration tests read
# TEST_DATABASE_URL; when it is unset the DB tests skip. Host-facing URL:
TEST_POSTGRES_DB=tvshow_test
TEST_DATABASE_URL=postgres://tvshow:change-me-dev-only@localhost:5433/tvshow_test

# ---------- Garage (S3) ----------
# 32-byte hex secrets. Generate with: openssl rand -hex 32
GARAGE_RPC_SECRET=change-me-generate-with-openssl-rand-hex-32
GARAGE_ADMIN_TOKEN=change-me-generate-with-openssl-rand-hex-32
# S3 access keys are created AFTER first boot via scripts/garage-init.sh,
# then pasted here so the backend can authenticate:
S3_ENDPOINT=http://garage:3900
S3_REGION=garage
S3_BUCKET=artwork
S3_ACCESS_KEY=set-after-running-garage-init
S3_SECRET_KEY=set-after-running-garage-init

# ---------- TheTVDB ----------
# Your own project-level API key (https://thetvdb.com/api-information). No per-user PIN.
THETVDB_API_KEY=your-project-api-key
THETVDB_BASE_URL=https://api4.thetvdb.com/v4

# ---------- Backend ----------
BACKEND_BIND_ADDR=0.0.0.0:8080
RUST_LOG=info,backend=debug
# Secret for signing JWT session tokens. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Optional password PEPPER: a secret Argon2 key mixed into every hash, kept out of
# the DB. Set once and NEVER change it (existing hashes won't verify if you do).
# Leave unset for salt-only. Generate with: openssl rand -hex 32
# PASSWORD_PEPPER=
# Public URL clients reach the API at (used to build absolute avatar/cover URLs).
PUBLIC_BASE_URL=http://localhost:8080
# Web app origin — used to build links in emails (password reset, invites).
WEB_BASE_URL=http://localhost:8080
# Registration: false (default) = invite-only; true = public sign-ups allowed.
# ALLOW_PUBLIC_REGISTRATION=false
# Email (SMTP) for password reset + invitations. Unset SMTP_HOST to disable sending
# (the link is logged instead — handy for local dev).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=Cinetrack <no-reply@localhost>
# Optional: run the /updates catalog sync worker in the server on this interval
# (seconds). Unset = disabled (use `cargo run --bin sync` manually / via cron).
# SYNC_INTERVAL_SECS=3600

# How the catalog sources data from TheTVDB (governs ALL catalog reads + search):
#   hybrid (default) — local mirror first; fall back to TheTVDB when thin and
#                       cache the results (best for dev + resilient prod).
#   mirror           — local DB only; never call TheTVDB (production goal; pair
#                       with the sync worker to keep the mirror fresh).
#   proxy            — pure read-through passthrough to TheTVDB.
# CATALOG_MODE=hybrid

# How much of TheTVDB the mirror holds (independent of CATALOG_MODE):
#   on-demand (default) — only mirror entities we're asked about; /updates
#                         reconciles those we already hold, doesn't add new ones.
#   full                — mirror the whole catalog (seed crawl via `bin/mirror` +
#                         /updates adds brand-new entities).
# Note: the /updates feed is global, so each sync scans all upstream changes in the
# window regardless of scope — run it often (small windows) to keep runs cheap.
# MIRROR_SCOPE=on-demand

# Max outbound requests/sec to TheTVDB (global pacer). Undocumented upstream; tune
# empirically (raise, watch for 429s, back off). Default 35.
# THETVDB_MAX_RPS=35

# Background enrichment worker: drains the fetch queue (stubs -> full records),
# at Low priority (yields to user requests). It's EVENT-DRIVEN — woken instantly
# whenever something is enqueued (search/discover stubs, /updates changes) — and
# this interval is only a fallback heartbeat to catch enqueues from OTHER
# processes (e.g. `bin/sync`). Setting it enables the worker; unset = disabled
# (use `cargo run --bin mirror` for an on-demand bulk fill). Calls TheTVDB, so
# leave off for a pure-offline deployment.
# ENRICH_INTERVAL_SECS=60
# ENRICH_CONCURRENCY=8
